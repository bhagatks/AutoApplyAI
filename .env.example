# Gemini API Key (Optional in .env since it's inputted in the application UI)
GEMINI_API_KEY=

# Firebase Client Configuration (Injected at build-time by Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry (optional — one project, tag surfaces in app)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=true
VITE_APP_VERSION=2.0.2

# EmailJS — support report delivery (build-time; set in .env.local for local builds)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
